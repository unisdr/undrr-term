{
  "name": "undrr-term",
  "version": "0.1.0",
  "description": "UNDRR multilingual terminology hub",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "compile": "node scripts/compile-to-json.js",
    "import:weblate": "node scripts/import-from-weblate.js",
    "export:csv": "node scripts/export-csv.js",
    "export:json": "node scripts/export-json.js",
    "import:csv": "node scripts/import-csv.js",
    "import:json": "node scripts/import-json.js",
    "xlsx-to-csv": "node scripts/xlsx-to-csv.js",
    "test": "bash tests/test-import-export.sh",
    "export:all": "node scripts/export-all.js",
    "build": "yarn run compile && yarn run export:all && cd site && yarn run build && mkdir -p _site/exports && cp ../exports/* _site/exports/",
    "dev": "cd site && yarn run dev"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
