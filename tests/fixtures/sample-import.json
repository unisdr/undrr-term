          "term": "Drought",
          "definition": "An extended period of unusually low precipitation that produces a shortage of water for people, animals, and plants.\n",
          "part_of_speech": "noun",
          "source": {
            "text": "UNDRR, 2017",
            "url": "https://www.undrr.org/publication/report-open-ended-intergovernmental-expert-working-group-indicators-and-terminology"
          }
        },
        "fr": {
          "term": "Sécheresse",
          "definition": "Une période prolongée de précipitations anormalement faibles qui entraîne une pénurie d'eau pour les personnes, les animaux et les plantes.",
          "part_of_speech": "nom",
          "source": {
            "text": "UNDRR, 2017",
            "url": "https://www.undrr.org/publication/report-open-ended-intergovernmental-expert-working-group-indicators-and-terminology"
          }
        },
