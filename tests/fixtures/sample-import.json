      "translations": {
        "en": {
          "term": "Flood",
          "definition": "The overflowing of the normal confines of a stream or other body of water, or the accumulation of water over areas not normally submerged.\n",
          "context": "The 2011 Thailand flood caused $45.7 billion in damages.",
          "part_of_speech": "noun",
          "aliases": ["Flooding"],
          "source": {
            "text": "UNDRR, 2017",
            "url": "https://www.undrr.org/publication/report-open-ended-intergovernmental-expert-working-group-indicators-and-terminology"
          }
        },
        "fr": {
          "term": "Inondation",
          "definition": "Le débordement des limites normales d'un cours d'eau ou d'un autre plan d'eau, ou l'accumulation d'eau sur des zones normalement non submergées.",
          "context": "L'inondation de 2016 a touché plusieurs départements du centre de la France.",
          "part_of_speech": "nom",
          "aliases": ["Crue"],
          "source": {
            "text": "UNDRR, 2017",
            "url": "https://www.undrr.org/publication/report-open-ended-intergovernmental-expert-working-group-indicators-and-terminology"
          }
        },
        "ar": {
