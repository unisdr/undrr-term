---js
{
  pagination: {
    data: "languages",
    size: 1,
    alias: "currentLang"
  },
  permalink: function(data) {
    return `/${data.currentLang.code}/`;
  },
  layout: "layouts/base.njk",
  eleventyComputed: {
    lang: (data) => data.currentLang.code,
    dir: (data) => data.currentLang.dir,
    pageTitle: (data) => data.i18n.site_subtitle[data.currentLang.code],
    langPath: () => ""
  }
}
---

{%- set lang = currentLang.code %}

<!-- <img src="https://assets.undrr.org/static/logos/pw/pw-logo.svg" alt="PreventionWeb" style="height: 40px; margin-bottom: 0.5rem;"> -->
<h1 style="margin: 0.25rem 0;">PreventionWeb Term</h1>
<p class="mg-u-font-size-600" style="margin-top: 0;">{{ i18n.site_subtitle[lang] }}</p>

<p class="mg-u-font-size-500" style="margin: 0 auto 2rem;">{{ i18n.site_intro[lang] }}</p>

<h2>{{ i18n.all_projects[lang] }}</h2>

{%- for project in projects %}
<div class="term-card mg-card mg-card__hc">
  <h3 class="mg-card__title" ><a href="{{ ('/' + lang + '/' + project.slug + '/') | url }}">{{ project.name }}</a></h3>
  <p>{{ project.description }}</p>
  <p class="term-meta">{{ terms | termsForProject(project.slug) | length }} terms</p>
</div>
{%- endfor %}

<p style="color: #666; font-style: italic;">{{ i18n.more_coming_soon[lang] }}</p>

<div class="mg-grid mg-grid__col-3">
  <article class="mg-card mg-card__hc">
    <div class="mg-card__content">
      <header class="mg-card__title">{{ i18n.card_multilingual_title[lang] }}</header>
      <p class="mg-card__summary">{{ i18n.card_multilingual_desc[lang] }}</p>
    </div>
  </article>
  <article class="mg-card mg-card__hc">
    <div class="mg-card__content">
      <header class="mg-card__title">{{ i18n.card_opendata_title[lang] }}</header>
      <p class="mg-card__summary">{{ i18n.card_opendata_desc[lang] }}</p>
    </div>
  </article>
  <article class="mg-card mg-card__hc">
    <div class="mg-card__content">
      <header class="mg-card__title">{{ i18n.card_community_title[lang] }}</header>
      <p class="mg-card__summary">{{ i18n.card_community_desc[lang] }}</p>
    </div>
  </article>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "PreventionWeb Term",
  "description": {{ i18n.site_subtitle[lang] | dump | safe }},
  "url": {{ (site.url + '/' + lang + '/') | dump | safe }},
  "inLanguage": {{ lang | dump | safe }},
  "publisher": {
    "@type": "Organization",
    "name": "United Nations Office for Disaster Risk Reduction",
    "alternateName": "UNDRR",
    "url": "https://www.undrr.org"
  }
}
</script>

