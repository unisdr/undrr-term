<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ dir or 'ltr' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pageTitle }} - {{ i18n.site_title[lang] }}</title>
  <link rel="stylesheet" href="https://assets.undrr.org/static/mangrove/1.3.3/css/style.css">
  <link rel="stylesheet" href="{{ '/assets/css/custom.css' | url }}">
</head>
<body>
  <header class="ecl-site-header" role="banner">
    <div class="ecl-container">
      <div style="display: flex; justify-content: space-between; align-items: center; padding: 1rem 0;">
        <a href="{{ ('/' + lang + '/') | url }}" style="text-decoration: none; color: inherit;">
          <strong>{{ i18n.site_title[lang] }}</strong>
        </a>
        <nav aria-label="Language">
          <ul style="list-style: none; display: flex; gap: 0.75rem; margin: 0; padding: 0;">
            {%- for l in languages %}
            <li>
              <a href="{{ ('/' + l.code + '/' + (langPath or '')) | url }}"
                 {% if l.code === lang %}aria-current="page" style="font-weight: bold;"{% endif %}>
                {{ l.name }}
              </a>
            </li>
            {%- endfor %}
          </ul>
        </nav>
      </div>
    </div>
  </header>

  <main class="ecl-container" style="padding: 2rem 0;">
    {{ content | safe }}
  </main>

  <footer style="border-top: 1px solid #ddd; padding: 1.5rem 0; margin-top: 3rem;">
    <div class="ecl-container">
      <p style="color: #666; font-size: 0.875rem;">UNDRR Terminology Hub</p>
    </div>
  </footer>
</body>
</html>
