<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ dir or 'ltr' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pageTitle }} - {{ i18n.site_title[lang] }}</title>
  <link rel="stylesheet" href="https://assets.undrr.org/static/mangrove/1.3.3/css/style.css">
  <link rel="stylesheet" href="https://assets.undrr.org/static/cookie-banner/v1/cookieconsent.css">
  <link rel="stylesheet" href="{{ '/assets/css/custom.css' | url }}">
</head>
<body>

  {# -- UNDRR global page header -- #}
  <header id="header" class="mg-page-header">
    <div class="mg-page-header__decoration">
      <div></div>
      <div></div>
      <div></div>
      <div></div>
    </div>
    <div class="mg-page-header__toolbar-wrapper" data-vf-google-analytics-region="undrr-black-bar">
      <div class="mg-page-header__container | mg-container">
        <div class="mg-page-header__region mg-page-header__region--toolbar">
          <section id="block-undrrlogo" class="mg-page-header__block mg-page-header__block--logo">
            <a href="https://www.undrr.org">
              <img
                alt="UNDRR Logo"
                src="https://assets.undrr.org/static/logos/undrr/undrr-logo-horizontal.svg"
                width="324"
                height="47"
                title="UNDRR Logo"
                class="mg-page-header__logo-img"
              />
            </a>
          </section>
          <div class="mg-page-header__block">
            <a href="{{ ('/' + lang + '/') | url }}" style="text-decoration: none; color: inherit;">
              <span class="mg-page-header__label">{{ i18n.site_title[lang] }}</span>
            </a>
          </div>
          <div class="mg-page-header__block">
            <div class="mg-page-header__form-item form-item form-type-select form-no-label">
              <label for="lang-dropdown-select" class="mg-u-sr-only">Select your language</label>
              <div class="mg-page-header__select-wrapper">
                <select style="width: 165px;"
                  class="mg-page-header__select lang-dropdown-select-element form-select"
                  id="lang-dropdown-select"
                  name="lang_dropdown_select"
                  onchange="window.location.href = '{{ '/' | url }}' + this.value + '/{{ langPath or '' }}'">
                  {%- for l in languages %}
                  <option value="{{ l.code }}" {% if l.code === lang %}selected{% endif %}>{{ l.name }}</option>
                  {%- endfor %}
                </select>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  {# -- Site navigation using Mangrove megamenu pattern -- #}
  <nav class="mg-mega-wrapper" aria-label="Main Navigation">
    <div class="mg-mega-topbar mg-mega-topbar--branded | mg-container-full-width">
      <a class="mg-mega-topbar__logo" href="{{ ('/' + lang + '/') | url }}" aria-label="{{ i18n.site_title[lang] }}">
        <span class="mg-page-header__label">{{ i18n.site_title[lang] }}</span>
      </a>
      <button
        class="mg-mega-topbar-mobile__icon-button"
        aria-label="Toggle navigation menu"
        aria-haspopup="true"
      >
        <span class="mg-icon mg-icon-menu" aria-hidden="true"></span>
      </button>
      <ul
        class="mg-mega-topbar__nav"
        role="menubar"
        aria-label="Main navigation menu"
      >
        {%- for project in projects %}
        <li class="mg-mega-topbar__item" role="none">
          <a
            class="mg-mega-topbar__item-link"
            href="{{ ('/' + lang + '/' + project.slug + '/') | url }}"
            role="menuitem"
          >
            {{ project.name }}
          </a>
        </li>
        {%- endfor %}
      </ul>
    </div>
    <div
      class="mg-mega-mobile-sidebar"
      role="dialog"
      aria-label="Mobile navigation menu"
    >
      <ul
        class="mg-mega-sidebar__list"
        role="menu"
        aria-label="Navigation options"
      >
        {%- for project in projects %}
        <li class="mg-mega-sidebar-section" role="none">
          <a class="mg-mega-sidebar-section__item" href="{{ ('/' + lang + '/' + project.slug + '/') | url }}" role="menuitem">
            <span>{{ project.name }}</span>
          </a>
        </li>
        {%- endfor %}
      </ul>
    </div>
  </nav>

  {# -- Main content area -- #}
  <main class="mg-container mg-container--padded mg-container--spacer">
    {{ content | safe }}
  </main>

  {# -- Footer with UNDRR syndicated global footer -- #}
  <footer class="mg-footer">
    <div class="pw-widget-footer"></div>
  </footer>

  <script src="https://publish.preventionweb.net/widget.js"></script>
  <script>
    new PW_Widget.initialize({
      contenttype: 'landingpage',
      pageid: '83835',
      includecss: false,
      suffixID: 'footer',
      activedomain: 'www.undrr.org'
    });
  </script>

  {# -- UNDRR standard scripts -- #}
  <script src="https://assets.undrr.org/static/analytics/v1.0.0/google_analytics_enhancements.js" defer></script>
  <script src="https://messaging.undrr.org/src/undrr-messaging.js" defer></script>
  <script src="https://assets.undrr.org/static/cookie-banner/v1/cookieconsent.umd.js" defer></script>
  <script src="https://assets.undrr.org/static/cookie-banner/v1/cookieconsent-undrr.js" defer></script>

</body>
</html>
