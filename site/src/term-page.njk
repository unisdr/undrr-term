---js
{
  pagination: {
    data: "collections.all",
    size: 1,
    before: function(data, fullData) {
      const combos = [];
      for (const lang of fullData.languages) {
        for (const term of fullData.terms) {
          combos.push({ lang, term });
        }
      }
      return combos;
    },
    alias: "combo"
  },
  permalink: function(data) {
    return `/${data.combo.lang.code}/${data.combo.term.project}/${data.combo.term.code}/`;
  },
  layout: "layouts/base.njk",
  eleventyComputed: {
    lang: (data) => data.combo.lang.code,
    dir: (data) => data.combo.lang.dir,
    pageTitle: (data) => {
      const lang = data.combo.lang.code;
      const t = data.combo.term.translations?.[lang] || data.combo.term.translations?.en;
      return t?.term || data.combo.term.id;
    },
    langPath: (data) => `${data.combo.term.project}/${data.combo.term.code}/`
  }
}
---

{%- set lang = combo.lang.code %}
{%- set term = combo.term %}
{%- set t = term.translations[lang] or term.translations.en %}

<ul aria-label="breadcrumbs" class="mg-breadcrumb">
  <li><a href="{{ ('/' + lang + '/') | url }}">{{ i18n.all_projects[lang] }}</a></li>
  <li><a href="{{ ('/' + lang + '/' + term.project + '/') | url }}">{{ term.projectConfig.name }}</a></li>
  <li aria-current="page">{{ t.term }}</li>
</ul>

{%- if term.status === "retired" %}
<div class="term-retired-banner" role="alert">
  {{ i18n.retired_notice[lang] or i18n.retired_notice.en }}
</div>
{%- endif %}

<div class="term-layout">

  {# -- Left sidebar: metadata -- #}
  <aside class="term-sidebar">

    {%- if term.domain and i18n.domain[term.domain] %}
    <div class="term-sidebar__section">
      <h3>{{ i18n.domain_label[lang] or "Domain" }}</h3>
      <p>{{ i18n.domain[term.domain][lang] or i18n.domain[term.domain].en }}</p>
    </div>
    {%- endif %}

    {%- if term.category %}
    <div class="term-sidebar__section">
      <h3>{{ i18n.category_label[lang] or "Category" }}</h3>
      <p>{{ term.category }}</p>
    </div>
    {%- endif %}

    <div class="term-sidebar__section">
      <h3>{{ i18n.source[lang] }}</h3>
      {%- if t.source.text %}
      <p>
        {%- if t.source.url %}<a href="{{ t.source.url }}">{{ t.source.text }}</a>
        {%- else %}{{ t.source.text }}{%- endif %}
      </p>
      {%- elif t.source %}
      <p>{{ t.source }}</p>
      {%- else %}
      <p>—</p>
      {%- endif %}
    </div>

    <div class="term-sidebar__section">
      <h3>{{ i18n.code_label[lang] or "Code" }}</h3>
      <p>{{ term.code }}</p>
    </div>

    {%- if term.related and term.related.length %}
    <div class="term-sidebar__section">
      <h3>{{ i18n.related_terms[lang] }}</h3>
      <ul>
        {%- for relId in term.related %}
          {%- set relTerm = false %}
          {%- for t2 in terms %}
            {%- if t2.id === relId %}
              {%- set relTerm = t2 %}
            {%- endif %}
          {%- endfor %}
          {%- if relTerm %}
            <li><a href="{{ ('/' + lang + '/' + relTerm.project + '/' + relTerm.code + '/') | url }}">{{ relTerm | termName(lang) }}</a></li>
          {%- else %}
            <li>{{ relId }}</li>
          {%- endif %}
        {%- endfor %}
      </ul>
    </div>
    {%- endif %}

    {%- set termStatus = term.status or "published" %}
    <div class="term-sidebar__section">
      <h3>{{ i18n.status_label[lang] or "Status" }}</h3>
      <p><span class="term-status-badge term-status-badge--{{ termStatus }}">{{ i18n['status_' + termStatus][lang] or termStatus }}</span></p>
    </div>

    <div class="term-sidebar__section">
      <h3>{{ i18n.confidence_label[lang] }}</h3>
      {%- for l in languages %}
        {%- set lt = term.translations[l.code] %}
        {%- if lt %}
        <p class="confidence-row">
          <span>{{ l.name }}:</span>
          {%- if lt.confidence %}
          <span class="term-confidence term-confidence--{{ lt.confidence }}">{{ i18n['confidence_' + lt.confidence][lang] }}</span>
          {%- else %}
          <span class="term-confidence term-confidence--0">{{ i18n.confidence_not_assessed[lang] }}</span>
          {%- endif %}
        </p>
        {%- endif %}
      {%- endfor %}
    </div>

    <div class="term-sidebar__section">
      <h3>{{ i18n.download_terms[lang] }}</h3>
      <div class="download-links download-links--sidebar">
        <select id="download-lang" class="download-select" data-project="{{ term.project }}" data-prefix="{{ '/' | url }}">
          <option value="">{{ i18n.download_all_languages[lang] }}</option>
          {%- for l in languages %}
            {%- if l.code !== "en" %}
          <option value="-{{ l.code }}"{% if l.code === lang and lang !== "en" %} selected{% endif %}>{{ i18n.download_english_plus[lang] }} {{ l.name }}</option>
            {%- endif %}
          {%- endfor %}
        </select>
        <span>
          {%- if lang !== "en" %}
          <a href="{{ ('/exports/' + term.project + '-' + lang + '.csv') | url }}" download class="download-csv" title="{{ i18n.download_csv_desc[lang] }}">CSV</a>
          &middot;
          <a href="{{ ('/exports/' + term.project + '-' + lang + '.json') | url }}" download class="download-json" title="{{ i18n.download_json_desc[lang] }}">JSON</a>
          {%- else %}
          <a href="{{ ('/exports/' + term.project + '.csv') | url }}" download class="download-csv" title="{{ i18n.download_csv_desc[lang] }}">CSV</a>
          &middot;
          <a href="{{ ('/exports/' + term.project + '.json') | url }}" download class="download-json" title="{{ i18n.download_json_desc[lang] }}">JSON</a>
          {%- endif %}
          &middot;
          <a href="{{ ('/exports/' + term.project + '.zip') | url }}" download class="download-zip" title="{{ i18n.download_zip_desc[lang] }}">ZIP</a>
        </span>
      </div>
    </div>

    <div class="term-sidebar__section">
      <a href="https://github.com/unisdr/undrr-term/edit/main/{{ term.sourcePath }}"
         class="mg-button mg-button-primary">
        {{ i18n.propose_revision[lang] or "Propose a revision" }}
      </a>
      <p class="term-sidebar__contributing"><a href="{{ ('/' + lang + '/contributing/') | url }}">{{ i18n.about_contributing[lang] or "About contributing edits" }}</a></p>
    </div>

  </aside>

  {# -- Right: language sections (UNTerm style: each language as a block) -- #}
  <div class="term-content">

    <h1>{{ t.term }}</h1>

    {%- if term.projectConfig.url %}
    <div class="translation-scope-notice">
      <p>{{ i18n.translation_scope_notice[lang] }} <a href="{{ term.projectConfig.url }}">{{ term.projectConfig.citation or term.projectConfig.name }}</a></p>
    </div>
    {%- endif %}

    {# Current language first #}
    <section class="term-lang-section">
      {%- for thisLang in languages %}
        {%- if thisLang.code === lang %}
      <h2 class="term-lang-heading mg-card mg-card__hc">{{ thisLang.name }}</h2>
        {%- endif %}
      {%- endfor %}

      <p class="term-name">
        {{ t.term }}
        {%- if t.part_of_speech %}
          <span class="term-pos">{{ t.part_of_speech }}</span>
        {%- endif %}
        {%- if t.confidence %}
          <span class="term-confidence term-confidence--{{ t.confidence }}" title="{{ i18n.confidence_label[lang] }}">{{ i18n['confidence_' + t.confidence][lang] }}</span>
        {%- endif %}
      </p>

      {%- if t.aliases and t.aliases.length %}
      <p class="term-aliases">{{ i18n.aliases[lang] }}: {{ t.aliases | join(", ") }}</p>
      {%- endif %}

      {%- if t.context %}
      <p><strong>{{ i18n.context[lang] }}:</strong> {{ t.context | mdInline | safe }}</p>
      {%- endif %}

      <h3>{{ i18n.definition[lang] }}</h3>
      {{ t.definition | md | safe }}
    </section>

    {%- if t.description %}
    <div class="term-detail-section">
      {{ t.description | md | safe }}
    </div>
    {%- endif %}

    {# Other languages #}
    <div class="term-other-languages">
      {%- for l in languages %}
        {%- if l.code !== lang and term.translations[l.code] %}
          {%- set lt = term.translations[l.code] %}
          <section class="term-lang-section mg-card mg-card__hc" lang="{{ l.code }}" dir="{{ l.dir or 'ltr' }}">
            <h2 class="term-lang-heading mg-card__title">
              <a href="{{ ('/' + l.code + '/' + term.project + '/' + term.code + '/') | url }}">{{ l.name }}</a>
            </h2>

            <p class="term-name">
              {{ lt.term }}
              {%- if lt.part_of_speech %}
                <span class="term-pos">{{ lt.part_of_speech }}</span>
              {%- endif %}
              {%- if lt.confidence %}
                <span class="term-confidence term-confidence--{{ lt.confidence }}" title="{{ i18n.confidence_label[l.code] or i18n.confidence_label[lang] }}">{{ i18n['confidence_' + lt.confidence][l.code] or i18n['confidence_' + lt.confidence][lang] }}</span>
              {%- endif %}
            </p>

            {%- if lt.aliases and lt.aliases.length %}
            <p class="term-aliases">{{ i18n.aliases[l.code] or i18n.aliases[lang] }}: {{ lt.aliases | join(", ") }}</p>
            {%- endif %}

            <h3>{{ i18n.definition[l.code] or i18n.definition[lang] }}</h3>
            {{ lt.definition | md | safe }}
          </section>
        {%- endif %}
      {%- endfor %}
    </div>

  </div>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "name": {{ t.term | dump | safe }},
  "description": {{ t.definition | plaintext | dump | safe }},
  "identifier": {{ term.code | dump | safe }},
  "inLanguage": {{ lang | dump | safe }},
  "url": {{ (site.url + '/' + lang + '/' + term.project + '/' + term.code + '/') | dump | safe }},
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "name": {{ term.projectConfig.name | dump | safe }},
    "url": {{ (site.url + '/' + lang + '/' + term.project + '/') | dump | safe }}
  }
}
</script>
<script>
  const langSelect = document.getElementById('download-lang');
  if (langSelect) {
    langSelect.addEventListener('change', () => {
      const project = langSelect.dataset.project;
      const prefix = langSelect.dataset.prefix;
      const suffix = langSelect.value;
      const container = langSelect.closest('.download-links');
      container.querySelector('.download-csv').href = prefix + 'exports/' + project + suffix + '.csv';
      container.querySelector('.download-json').href = prefix + 'exports/' + project + suffix + '.json';
    });
  }
</script>
