---js
{
  pagination: {
    data: "collections.all",
    size: 1,
    before: function(data, fullData) {
      const combos = [];
      for (const lang of fullData.languages) {
        for (const term of fullData.terms) {
          combos.push({ lang, term });
        }
      }
      return combos;
    },
    alias: "combo"
  },
  permalink: function(data) {
    return `/${data.combo.lang.code}/${data.combo.term.project}/${data.combo.term.code}/`;
  },
  layout: "layouts/base.njk",
  eleventyComputed: {
    lang: (data) => data.combo.lang.code,
    dir: (data) => data.combo.lang.dir,
    pageTitle: (data) => {
      const lang = data.combo.lang.code;
      const t = data.combo.term.translations?.[lang] || data.combo.term.translations?.en;
      return t?.term || data.combo.term.id;
    },
    langPath: (data) => `${data.combo.term.project}/${data.combo.term.code}/`
  }
}
---

{%- set lang = combo.lang.code %}
{%- set term = combo.term %}
{%- set t = term.translations[lang] or term.translations.en %}

<nav aria-label="breadcrumbs" class="mg-breadcrumb">
  <ul>
    <li><a href="{{ ('/' + lang + '/') | url }}">{{ i18n.all_projects[lang] }}</a></li>
    <li><a href="{{ ('/' + lang + '/' + term.project + '/') | url }}">{{ term.projectConfig.name }}</a></li>
    <li aria-current="page">{{ t.term }}</li>
  </ul>
</nav>

<h1>{{ t.term }}</h1>

{%- if t.part_of_speech or (term.domain and i18n.domain[term.domain]) %}
<div class="mg-tag-container">
  {%- if t.part_of_speech %}
    <span>{{ t.part_of_speech }}</span>
  {%- endif %}
  {%- if term.domain and i18n.domain[term.domain] %}
    <span>{{ i18n.domain[term.domain][lang] or i18n.domain[term.domain].en }}</span>
  {%- endif %}
  <span>{{ term.code }}</span>
</div>
{%- endif %}

<div class="term-detail-section">
  <h3>{{ i18n.definition[lang] }}</h3>
  {{ t.definition | md | safe }}
</div>

{%- if t.context %}
<div class="term-detail-section">
  <h3>{{ i18n.context[lang] }}</h3>
  <p>{{ t.context | mdInline | safe }}</p>
</div>
{%- endif %}

{%- if t.aliases and t.aliases.length %}
<div class="term-detail-section">
  <h3>{{ i18n.aliases[lang] }}</h3>
  <p>{{ t.aliases | join(", ") }}</p>
</div>
{%- endif %}

{%- if t.source %}
<div class="term-detail-section">
  <h3>{{ i18n.source[lang] }}</h3>
  <p>{{ t.source }}</p>
</div>
{%- endif %}

{%- if term.related and term.related.length %}
<div class="term-detail-section">
  <h3>{{ i18n.related_terms[lang] }}</h3>
  <ul>
    {%- for relId in term.related %}
      {%- set relTerm = false %}
      {%- for t2 in terms %}
        {%- if t2.id === relId %}
          {%- set relTerm = t2 %}
        {%- endif %}
      {%- endfor %}
      {%- if relTerm %}
        <li><a href="{{ ('/' + lang + '/' + relTerm.project + '/' + relTerm.code + '/') | url }}">{{ relTerm | termName(lang) }}</a></li>
      {%- else %}
        <li>{{ relId }}</li>
      {%- endif %}
    {%- endfor %}
  </ul>
</div>
{%- endif %}

{%- if t.description %}
<div class="term-detail-section">
  {{ t.description | md | safe }}
</div>
{%- endif %}

<div class="term-detail-section">
  <h3>{{ i18n.languages_label[lang] }}</h3>
  <div class="mg-grid mg-grid__col-3">
    {%- for l in languages %}
      {%- if l.code !== lang and term.translations[l.code] %}
        {%- set lt = term.translations[l.code] %}
        <div class="language-card">
          <h4>{{ l.name }}</h4>
          <p><strong>{{ lt.term }}</strong></p>
          {%- if lt.definition %}
            <p class="mg-u-font-size-150 mg-u-color--neutral-600">{{ lt.definition | truncate(200) | mdInline | safe }}</p>
          {%- endif %}
          <a href="{{ ('/' + l.code + '/' + term.project + '/' + term.code + '/') | url }}">
            View in {{ l.name }} &rarr;
          </a>
        </div>
      {%- endif %}
    {%- endfor %}
  </div>
</div>

<div class="term-edit-link">
  <a href="https://github.com/undrr/undrr-term/edit/main/terms/{{ term.project }}/{{ term.code }}.md"
     class="mg-u-font-size-150 mg-u-color--neutral-600">
    {{ i18n.edit_on_github[lang] }}
  </a>
</div>
